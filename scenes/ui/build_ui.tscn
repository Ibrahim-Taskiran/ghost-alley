[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/build_ui.gd" id="1_build_ui_script"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_window"]
bg_color = Color(0.08, 0.09, 0.11, 0.9)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.18, 0.2, 0.24, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_left = 8
corner_radius_bottom_right = 8

[node name="BuildUI" type="Control" groups=["BuildUI"]]
layout_mode = 3
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -200.0
offset_top = -140.0
offset_right = 200.0
offset_bottom = -20.0
grow_horizontal = 2
grow_vertical = 0
script = ExtResource("1_build_ui_script")

[node name="BackgroundPanel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_window")

[node name="Margin" type="MarginContainer" parent="BackgroundPanel"]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="BackgroundPanel/Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Header" type="HBoxContainer" parent="BackgroundPanel/Margin/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="BackgroundPanel/Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.9, 0.8, 0.6, 1)
theme_override_font_sizes/font_size = 14
text = "İnşaat Arayüzü [B]"

[node name="CloseButton" type="Button" parent="BackgroundPanel/Margin/VBox/Header"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = " X "

[node name="Grid" type="GridContainer" parent="BackgroundPanel/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/horizontal_separation = 12
columns = 3

[node name="BuildFenceBtn" type="Button" parent="BackgroundPanel/Margin/VBox/Grid"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 12
text = "Ahşap Çit
(5 Tahta)"

[node name="BuildBarricadeBtn" type="Button" parent="BackgroundPanel/Margin/VBox/Grid"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 12
text = "Metal Barikat
(8 Metal, Müh 3)"

[node name="BuildBedBtn" type="Button" parent="BackgroundPanel/Margin/VBox/Grid"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 12
text = "Yatak
(3 Tahta)"


[connection signal="pressed" from="BackgroundPanel/Margin/VBox/Header/CloseButton" to="." method="close_build_menu"]
[connection signal="pressed" from="BackgroundPanel/Margin/VBox/Grid/BuildFenceBtn" to="." method="_on_build_fence_pressed"]
[connection signal="pressed" from="BackgroundPanel/Margin/VBox/Grid/BuildBarricadeBtn" to="." method="_on_build_barricade_pressed"]
[connection signal="pressed" from="BackgroundPanel/Margin/VBox/Grid/BuildBedBtn" to="." method="_on_build_bed_pressed"]

